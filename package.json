{
  "name": "@jtrb/runtime",
  "version": "0.1.1",
  "description": "A browser-based C runtime powered by WASM, with stdin/stdout/stderr streams and a debugger",
  "keywords": [
    "wasm",
    "runtime",
    "c",
    "debugger",
    "dap"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jacobrobertsbaca/runtime.git"
  },
  "type": "module",
  "main": "./dist/runtime.umd.cjs",
  "module": "./dist/runtime.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/runtime.js",
      "require": "./dist/runtime.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "wasm-pack build --target web --debug && vite build",
    "build": "wasm-pack build --target web && vite build",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^22.13.1",
    "eslint": "^9.39.2",
    "events": "^3.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "tsify": "^5.0.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  }
}
