{
  "steps": [
    {
      "type": "request",
      "command": "setBreakpoints",
      "arguments": {
        "source": { "path": "main.cpp" },
        "breakpoints": [{ "line": 13 }]
      }
    },
    {
      "type": "response",
      "body": {
        "breakpoints": {
          "$array.contains": [{ "line": 13, "verified": true }]
        }
      }
    },
    {
      "type": "request",
      "command": "configurationDone",
      "arguments": {}
    },
    {
      "type": "event",
      "event": "stopped",
      "body": {
        "reason": "breakpoint",
        "threadId": "${{thread}}"
      }
    },
    {
      "type": "request",
      "command": "stackTrace",
      "arguments": { "threadId": "{{thread}}" }
    },
    {
      "type": "response",
      "body": {
        "stackFrames": {
          "$array.contains": [{ "name": "main", "id": "${{mainFrame}}" }]
        }
      }
    },
    {
      "type": "request",
      "command": "scopes",
      "arguments": { "frameId": "{{mainFrame}}" }
    },
    {
      "type": "response",
      "body": {
        "scopes": {
          "$array.contains": [
            {
              "name": "Locals",
              "variablesReference": "${{locals}}"
            }
          ]
        }
      }
    },
    {
      "type": "request",
      "command": "variables",
      "arguments": {
        "variablesReference": "{{locals}}"
      }
    },
    {
      "type": "response",
      "body": {
        "variables": [
          {
            "name": "rect",
            "type": "Rectangle",
            "memoryReference": "${{rect_addr}}",
            "variablesReference": "${{rect}}"
          }
        ]
      }
    },
    {
      "type": "request",
      "command": "variables",
      "arguments": {
        "variablesReference": "{{rect}}"
      }
    },
    {
      "type": "response",
      "body": {
        "variables": [
          {
            "name": "p1",
            "type": "Point",
            "memoryReference": "${{p1_addr}}",
            "variablesReference": "${{p1}}"
          },
          {
            "name": "p2",
            "type": "Point",
            "memoryReference": "${{p2_addr}}",
            "variablesReference": "${{p2}}"
          }
        ]
      }
    },
    {
      "type": "request",
      "command": "variables",
      "arguments": {
        "variablesReference": "{{p1}}"
      }
    },
    {
      "type": "response",
      "body": {
        "variables": [
          {
            "name": "x",
            "type": "int",
            "memoryReference": "${{p1_x_addr}}"
          },
          { "name": "y", "type": "int", "memoryReference": "${{p1_y_addr}}" }
        ]
      }
    },
    {
      "type": "request",
      "command": "variables",
      "arguments": {
        "variablesReference": "{{p2}}"
      }
    },
    {
      "type": "response",
      "body": {
        "variables": [
          { "name": "x", "type": "int", "memoryReference": "${{p2_x_addr}}" },
          { "name": "y", "type": "int", "memoryReference": "${{p2_y_addr}}" }
        ]
      }
    },
    {
      "type": "request",
      "command": "continue",
      "arguments": { "threadId": "{{thread}}" }
    },
    {
      /** Expect that p1 is in the right location inside of rect */
      "type": "expect",
      "run": "hex(p1_addr)",
      "expect": "{{hex(rect_addr)}}"
    },
    {
      /** Expect that p2 is in the right location inside of rect */
      "type": "expect",
      "run": "hex(p2_addr)",
      "expect": "{{hex(rect_addr) + 8}}"
    },
    {
      /** Expect that p1.x is in the right location */
      "type": "expect",
      "run": "hex(p1_x_addr)",
      "expect": "{{hex(p1_addr)}}"
    },
    {
      /** Expect that p1.y is in the right location */
      "type": "expect",
      "run": "hex(p1_y_addr)",
      "expect": "{{hex(p1_addr) + 4}}"
    },
    {
      /** Expect that p2.x is in the right location */
      "type": "expect",
      "run": "hex(p2_x_addr)",
      "expect": "{{hex(p2_addr)}}"
    },
    {
      /** Expect that p2.y is in the right location */
      "type": "expect",
      "run": "hex(p2_y_addr)",
      "expect": "{{hex(p2_addr) + 4}}"
    }
  ]
}
