{
  "steps": [
    {
      "type": "request",
      "command": "setBreakpoints",
      "arguments": {
        "source": { "path": "main.cpp" },
        "breakpoints": [{ "line": 10 }]
      }
    },
    {
      "type": "response",
      "body": {
        "breakpoints": {
          "$array.contains": [{ "line": 10, "verified": true }]
        }
      }
    },
    {
      "type": "request",
      "command": "configurationDone",
      "arguments": {}
    },
    {
      "type": "event",
      "event": "stopped",
      "body": {
        "reason": "breakpoint",
        "threadId": "${{thread}}"
      }
    },
    {
      "type": "request",
      "command": "stackTrace",
      "arguments": { "threadId": "{{thread}}" }
    },
    {
      "type": "response",
      "body": {
        "stackFrames": {
          "$array.contains": [{ "name": "main", "id": "${{mainFrame}}" }]
        }
      }
    },
    {
      "type": "request",
      "command": "scopes",
      "arguments": { "frameId": "{{mainFrame}}" }
    },
    {
      "type": "response",
      "body": {
        "scopes": {
          "$array.contains": [{ "name": "Locals", "variablesReference": "${{locals}}" }]
        }
      }
    },
    {
      "type": "request",
      "command": "variables",
      "arguments": { "variablesReference": "{{locals}}" }
    },
    {
      "type": "response",
      "body": {
        "variables": {
          "$array.contains": [
            { "name": "s", "indexedVariables": 3, "variablesReference": "${{set}}" },
            { "name": "m", "indexedVariables": 20, "variablesReference": "${{map}}" }
          ]
        }
      }
    },
    {
      "type": "request",
      "command": "variables",
      "arguments": { "variablesReference": "{{set}}" }
    },
    {
      "type": "response",
      "body": {
        "variables": [
          { "name": "[0]", "type": "int", "value": "10", "variablesReference": 0 },
          { "name": "[1]", "type": "int", "value": "20", "variablesReference": 0 },
          { "name": "[2]", "type": "int", "value": "30", "variablesReference": 0 }
        ]
      }
    },
    {
      "type": "request",
      "command": "variables",
      "arguments": { "variablesReference": "{{map}}" }
    },
    {
      "type": "response",
      "body": {
        "variables": {
          "$array.contains": [
            { "name": "[0]", "type": "std::pair<const int, int>", "variablesReference": "${{map0}}" },
            { "name": "[19]", "type": "std::pair<const int, int>", "variablesReference": "${{map19}}" }
          ]
        }
      }
    },
    {
      "type": "request",
      "command": "variables",
      "arguments": {
        "variablesReference": "{{map}}",
        "filter": "indexed",
        "start": 7,
        "count": 4
      }
    },
    {
      "type": "response",
      "body": {
        "variables": [
          { "name": "[7]", "type": "std::pair<const int, int>", "variablesReference": "${{map7}}" },
          { "name": "[8]", "type": "std::pair<const int, int>" },
          { "name": "[9]", "type": "std::pair<const int, int>" },
          { "name": "[10]", "type": "std::pair<const int, int>" }
        ]
      }
    },
    {
      "type": "request",
      "command": "variables",
      "arguments": { "variablesReference": "{{map7}}" }
    },
    {
      "type": "response",
      "body": {
        "variables": [
          { "name": "first", "value": "8", "variablesReference": 0 },
          { "name": "second", "value": "800", "variablesReference": 0 }
        ]
      }
    },
    {
      "type": "request",
      "command": "variables",
      "arguments": {
        "variablesReference": "{{map}}",
        "filter": "indexed",
        "start": 17,
        "count": 10
      }
    },
    {
      "type": "response",
      "body": {
        "variables": [
          { "name": "[17]", "type": "std::pair<const int, int>" },
          { "name": "[18]", "type": "std::pair<const int, int>" },
          { "name": "[19]", "type": "std::pair<const int, int>" }
        ]
      }
    },
    {
      "type": "request",
      "command": "variables",
      "arguments": { "variablesReference": "{{map0}}" }
    },
    {
      "type": "response",
      "body": {
        "variables": [
          { "name": "first", "value": "1", "variablesReference": 0 },
          { "name": "second", "value": "100", "variablesReference": 0 }
        ]
      }
    },
    {
      "type": "request",
      "command": "variables",
      "arguments": { "variablesReference": "{{map19}}" }
    },
    {
      "type": "response",
      "body": {
        "variables": [
          { "name": "first", "value": "20", "variablesReference": 0 },
          { "name": "second", "value": "2000", "variablesReference": 0 }
        ]
      }
    },
    {
      "type": "request",
      "command": "continue",
      "arguments": { "threadId": "{{thread}}" }
    }
  ]
}
