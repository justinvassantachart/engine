{
  "steps": [
    {
      "type": "request",
      "command": "setBreakpoints",
      "arguments": {
        "source": { "path": "main.cpp" },
        "breakpoints": [{ "line": 7 }]
      }
    },
    {
      "type": "response",
      "body": {
        "breakpoints": {
          "$array.contains": [{ "line": 7, "verified": true }]
        }
      }
    },
    {
      "type": "request",
      "command": "configurationDone",
      "arguments": {}
    },
    {
      "type": "event",
      "event": "stopped",
      "body": {
        "reason": "breakpoint",
        "threadId": "${{thread}}"
      }
    },
    {
      "type": "request",
      "command": "stackTrace",
      "arguments": { "threadId": "{{thread}}" }
    },
    {
      "type": "response",
      "body": {
        "stackFrames": {
          "$array.contains": [{ "name": "main", "id": "${{mainFrame}}" }]
        }
      }
    },
    {
      "type": "request",
      "command": "scopes",
      "arguments": { "frameId": "{{mainFrame}}" }
    },
    {
      "type": "response",
      "body": {
        "scopes": {
          "$array.contains": [{ "name": "Locals", "variablesReference": "${{locals}}" }]
        }
      }
    },
    {
      "type": "request",
      "command": "variables",
      "arguments": { "variablesReference": "{{locals}}" }
    },
    {
      "type": "response",
      "body": {
        "variables": {
          "$array.contains": [
            { "name": "s", "indexedVariables": 3, "variablesReference": "${{set}}" },
            { "name": "m", "indexedVariables": 3, "variablesReference": "${{map}}" }
          ]
        }
      }
    },
    {
      "type": "request",
      "command": "variables",
      "arguments": { "variablesReference": "{{set}}" }
    },
    {
      "type": "response",
      "body": {
        "variables": [
          { "name": "[0]", "type": "int", "value": "10", "variablesReference": 0 },
          { "name": "[1]", "type": "int", "value": "20", "variablesReference": 0 },
          { "name": "[2]", "type": "int", "value": "30", "variablesReference": 0 }
        ]
      }
    },
    {
      "type": "request",
      "command": "variables",
      "arguments": { "variablesReference": "{{map}}" }
    },
    {
      "type": "response",
      "body": {
        "variables": [
          { "name": "[0]", "type": "std::pair<const int, int>", "variablesReference": "${{map0}}" },
          { "name": "[1]", "type": "std::pair<const int, int>", "variablesReference": "${{map1}}" },
          { "name": "[2]", "type": "std::pair<const int, int>", "variablesReference": "${{map2}}" }
        ]
      }
    },
    {
      "type": "request",
      "command": "variables",
      "arguments": { "variablesReference": "{{map0}}" }
    },
    {
      "type": "response",
      "body": {
        "variables": [
          { "name": "first", "value": "1", "variablesReference": 0 },
          { "name": "second", "value": "100", "variablesReference": 0 }
        ]
      }
    },
    {
      "type": "request",
      "command": "continue",
      "arguments": { "threadId": "{{thread}}" }
    }
  ]
}
