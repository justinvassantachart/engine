// Benchmark for the built-in std::vector formatter: expanding a
// populated std::vector<int> must surface its elements as [0], [1], [2]
// rather than the raw libc++ layout (__begin_, __end_, __end_cap_).
// See tools/dap/output/formatting/log.json for the request/response stream.
{
  "steps": [
    {
      "type": "request",
      "command": "setBreakpoints",
      "arguments": {
        "source": { "path": "main.cpp" },
        "breakpoints": [{ "line": 5 }]
      }
    },
    {
      "type": "response",
      "body": {
        "breakpoints": {
          "$array.contains": [{ "line": 5, "verified": true }]
        }
      }
    },
    {
      "type": "request",
      "command": "configurationDone",
      "arguments": {}
    },
    {
      "type": "event",
      "event": "stopped",
      "body": {
        "reason": "breakpoint",
        "threadId": "${{thread}}"
      }
    },
    {
      "type": "request",
      "command": "stackTrace",
      "arguments": { "threadId": "{{thread}}" }
    },
    {
      "type": "response",
      "body": {
        "stackFrames": {
          "$array.contains": [{ "name": "main", "id": "${{mainFrame}}" }]
        }
      }
    },
    {
      "type": "request",
      "command": "scopes",
      "arguments": { "frameId": "{{mainFrame}}" }
    },
    {
      "type": "response",
      "body": {
        "scopes": {
          "$array.contains": [
            {
              "name": "Locals",
              "variablesReference": "${{locals}}"
            }
          ]
        }
      }
    },
    {
      "type": "request",
      "command": "variables",
      "arguments": {
        "variablesReference": "{{locals}}"
      }
    },
    {
      "type": "response",
      "body": {
        "variables": {
          "$array.contains": [
            {
              "name": "v",
              "indexedVariables": 3,
              "variablesReference": "${{vec}}"
            }
          ]
        }
      }
    },
    // Drill into the vector itself. The formatter should expose only the
    // contained elements, not the raw libc++ members.
    {
      "type": "request",
      "command": "variables",
      "arguments": {
        "variablesReference": "{{vec}}"
      }
    },
    {
      "type": "response",
      "body": {
        "variables": [
          { "name": "[0]", "value": "10", "variablesReference": 0 },
          { "name": "[1]", "value": "20", "variablesReference": 0 },
          { "name": "[2]", "value": "30", "variablesReference": 0 }
        ]
      }
    },
    {
      "type": "request",
      "command": "continue",
      "arguments": { "threadId": "{{thread}}" }
    }
  ]
}
