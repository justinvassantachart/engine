{
  "steps": [
    {
      "type": "request",
      "command": "setBreakpoints",
      "arguments": {
        "source": { "path": "main.cpp" },
        "breakpoints": [{ "line": 18 }]
      }
    },
    {
      "type": "response",
      "body": {
        "breakpoints": {
          "$array.contains": [{ "line": 18, "verified": true }]
        }
      }
    },
    {
      "type": "request",
      "command": "configurationDone",
      "arguments": {}
    },
    {
      "type": "event",
      "event": "stopped",
      "body": {
        "reason": "breakpoint",
        "threadId": "${{thread}}"
      }
    },
    {
      "type": "request",
      "command": "stackTrace",
      "arguments": { "threadId": "{{thread}}" }
    },
    {
      "type": "response",
      "body": {
        "stackFrames": {
          "$array.contains": [{ "id": "${{mainFrame}}", "name": "main" }]
        }
      }
    },
    {
      "type": "request",
      "command": "scopes",
      "arguments": { "frameId": "{{mainFrame}}" }
    },
    {
      "type": "response",
      "body": {
        "scopes": {
          "$array.contains": [
            {
              "name": "Locals",
              "variablesReference": "${{locals}}"
            }
          ]
        }
      }
    },
    {
      "type": "request",
      "command": "variables",
      "arguments": {
        "variablesReference": "{{locals}}"
      }
    },
    {
      "type": "response",
      "body": {
        "variables": {
          "$array.contains": [
            {
              "name": "deep_chrono",
              "type": "std::chrono::time_point<std::chrono::system_clock, std::chrono::duration<long long, std::ratio<1LL, 1000000000LL> > >"
            },
            {
              "name": "namespaced",
              "type": "custom::Widget",
              "variablesReference": "${{namespaced}}"
            },
            {
              "name": "via_typedef",
              "type": "custom::WidgetTypedef"
            },
            {
              "name": "via_using",
              "type": "custom::WidgetUsing"
            },
            {
              "name": "via_nested_using",
              "type": "custom::Widget::Value"
            }
          ]
        }
      }
    },
    {
      "type": "request",
      "command": "variables",
      "arguments": {
        "variablesReference": "{{namespaced}}"
      }
    },
    {
      "type": "response",
      "body": {
        "variables": {
          "$array.contains": [
            {
              "name": "value",
              "type": "custom::Widget::Value"
            }
          ]
        }
      }
    },
    {
      "type": "request",
      "command": "continue",
      "arguments": { "threadId": "{{thread}}" }
    }
  ]
}
