{
  "steps": [
    {
      "type": "request",
      "command": "setBreakpoints",
      "arguments": {
        "source": { "path": "main.cpp" },
        "breakpoints": [{ "line": 2 }]
      }
    },
    {
      "type": "response",
      "body": {
        "breakpoints": {
          "$array.contains": [{ "line": 2, "verified": true }]
        }
      }
    },
    {
      "type": "request",
      "command": "configurationDone",
      "arguments": {}
    },
    {
      "type": "event",
      "event": "stopped",
      "body": { "reason": "breakpoint", "threadId": "${{thread}}" }
    },
    {
      "type": "request",
      "command": "stackTrace",
      "arguments": { "threadId": "{{thread}}" }
    },
    {
      "type": "response",
      "body": {
        "stackFrames": {
          "$array.contains": [
            { "name": "bar", "id": "${{barFrame}}" },
            { "name": "foo", "id": "${{fooFrame}}" }
          ]
        }
      }
    },
    {
      "type": "request",
      "command": "stepOut",
      "arguments": { "threadId": "{{thread}}" }
    },
    {
      "type": "event",
      "event": "stopped",
      "body": { "reason": "step", "threadId": "{{thread}}" }
    },
    {
      "type": "request",
      "command": "stackTrace",
      "arguments": { "threadId": "{{thread}}" }
    },
    {
      "type": "response",
      "body": {
        "stackFrames": {
          "$array.contains": [
            { "name": "foo", "id": "${{fooFrame2}}" }
          ]
        }
      }
    },
    {
      "type": "request",
      "command": "continue",
      "arguments": { "threadId": "{{thread}}" }
    }
  ]
}