// Exercises DAP's paged variables request fields (`filter`, `start`, and
// `count`) against the std::vector formatter. The adapter should advertise the
// full indexed child count but only materialize the requested slice.
{
  "steps": [
    {
      "type": "request",
      "command": "setBreakpoints",
      "arguments": {
        "source": { "path": "main.cpp" },
        "breakpoints": [{ "line": 5 }]
      }
    },
    {
      "type": "response",
      "body": {
        "breakpoints": {
          "$array.contains": [{ "line": 5, "verified": true }]
        }
      }
    },
    {
      "type": "request",
      "command": "configurationDone",
      "arguments": {}
    },
    {
      "type": "event",
      "event": "stopped",
      "body": {
        "reason": "breakpoint",
        "threadId": "${{thread}}"
      }
    },
    {
      "type": "request",
      "command": "stackTrace",
      "arguments": { "threadId": "{{thread}}" }
    },
    {
      "type": "response",
      "body": {
        "stackFrames": {
          "$array.contains": [{ "name": "main", "id": "${{mainFrame}}" }]
        }
      }
    },
    {
      "type": "request",
      "command": "scopes",
      "arguments": { "frameId": "{{mainFrame}}" }
    },
    {
      "type": "response",
      "body": {
        "scopes": {
          "$array.contains": [
            {
              "name": "Locals",
              "variablesReference": "${{locals}}"
            }
          ]
        }
      }
    },
    {
      "type": "request",
      "command": "variables",
      "arguments": {
        "variablesReference": "{{locals}}"
      }
    },
    {
      "type": "response",
      "body": {
        "variables": {
          "$array.contains": [
            {
              "name": "v",
              "value": "size=6",
              "indexedVariables": 6,
              "variablesReference": "${{vec}}"
            }
          ]
        }
      }
    },
    {
      "type": "request",
      "command": "variables",
      "arguments": {
        "variablesReference": "{{vec}}",
        "filter": "indexed",
        "start": 2,
        "count": 3
      }
    },
    {
      "type": "response",
      "body": {
        "variables": [
          { "name": "[2]", "value": "30", "variablesReference": 0 },
          { "name": "[3]", "value": "40", "variablesReference": 0 },
          { "name": "[4]", "value": "50", "variablesReference": 0 }
        ]
      }
    },
    {
      "type": "request",
      "command": "variables",
      "arguments": {
        "variablesReference": "{{vec}}",
        "filter": "indexed",
        "start": 5,
        "count": 10
      }
    },
    {
      "type": "response",
      "body": {
        "variables": [{ "name": "[5]", "value": "60", "variablesReference": 0 }]
      }
    },
    {
      "type": "request",
      "command": "continue",
      "arguments": { "threadId": "{{thread}}" }
    }
  ]
}
