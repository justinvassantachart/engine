{
    "steps": [
      {
        "type": "request",
        "command": "setBreakpoints",
        "arguments": {
          "source": { "path": "main.cpp" },
          "breakpoints": [{ "line": 6 }]
        }
      },
      {
        "type": "response",
        "body": {
          "breakpoints": {
            "$array.contains": [{ "line": 6, "verified": true }]
          }
        }
      },
      {
        "type": "request",
        "command": "configurationDone",
        "arguments": {}
      },
      {
        "type": "event",
        "event": "stopped",
        "body": { "reason": "breakpoint", "threadId": "${{thread}}" }
      },
      {
        "type": "request",
        "command": "next",
        "arguments": { "threadId": "{{thread}}" }
      },
      {
        "type": "event",
        "event": "stopped",
        "body": { "reason": "step", "threadId": "{{thread}}" }
      },
      {
        "type": "request",
        "command": "stackTrace",
        "arguments": { "threadId": "{{thread}}" }
      },
      {
        "type": "response",
        "body": {
          "stackFrames": {
            "$array.excludes": [
              { "name": "bar" }
            ]
          }
        }
      },
      {
        "type": "request",
        "command": "continue",
        "arguments": { "threadId": "{{thread}}" }
      }
    ]
  }