{
  "steps": [
    {
      "type": "request",
      "command": "setBreakpoints",
      "arguments": {
        "source": { "path": "main.cpp" },
        "breakpoints": [{ "line": 15 }]
      }
    },
    {
      "type": "response",
      "body": {
        "breakpoints": {
          "$array.contains": [{ "line": 15, "verified": true }]
        }
      }
    },
    {
      "type": "request",
      "command": "configurationDone",
      "arguments": {}
    },
    {
      "type": "event",
      "event": "stopped",
      "body": {
        "reason": "breakpoint",
        "threadId": "${{thread}}"
      }
    },
    {
      "type": "request",
      "command": "stackTrace",
      "arguments": { "threadId": "{{thread}}" }
    },
    {
      "type": "response",
      "body": {
        "stackFrames": {
          "$array.contains": [{ "id": "${{mainFrame}}", "name": "main" }]
        }
      }
    },
    {
      "type": "request",
      "command": "scopes",
      "arguments": { "frameId": "{{mainFrame}}" }
    },
    {
      "type": "response",
      "body": {
        "scopes": {
          "$array.contains": [
            {
              "name": "Locals",
              "variablesReference": "${{locals}}"
            }
          ]
        }
      }
    },
    {
      "type": "request",
      "command": "variables",
      "arguments": {
        "variablesReference": "{{locals}}"
      }
    },
    {
      "type": "response",
      "body": {
        "variables": {
          "$array.contains": [
            { "name": "cref", "variablesReference": "${{cref}}" },
            { "name": "cptr", "variablesReference": "${{cptr}}" },
            { "name": "null", "variablesReference": 0 },
            { "name": "lref", "value": "1", "variablesReference": 0 },
            { "name": "lptr", "variablesReference": "${{lptr}}" }
          ]
        }
      }
    },
    {
      "type": "request",
      "command": "variables",
      "arguments": {
        "variablesReference": "{{cref}}"
      }
    },
    {
      "type": "response",
      "body": {
        "variables": {
          "$array.contains": [
            { "name": "a", "type": "long", "value": "1" },
            { "name": "b", "type": "long", "value": "2" }
          ]
        }
      }
    },
    {
      "type": "request",
      "command": "variables",
      "arguments": {
        "variablesReference": "{{cptr}}"
      }
    },
    {
      "type": "response",
      "body": {
        "variables": {
          "$array.contains": [
            { "name": "a", "type": "long", "value": "1" },
            { "name": "b", "type": "long", "value": "2" }
          ]
        }
      }
    },
    {
      "type": "request",
      "command": "variables",
      "arguments": {
        "variablesReference": "{{lptr}}"
      }
    },
    {
      "type": "response",
      "body": {
        "variables": {
          "$array.contains": [{ "name": "*lptr", "type": "long", "value": "1" }]
        }
      }
    },
    {
      "type": "request",
      "command": "continue",
      "arguments": { "threadId": "{{thread}}" }
    }
  ]
}
