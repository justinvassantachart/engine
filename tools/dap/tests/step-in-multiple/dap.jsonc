{
  "steps": [
    {
      "type": "request",
      "command": "setBreakpoints",
      "arguments": {
        "source": { "path": "main.cpp" },
        "breakpoints": [{ "line": 11 }]
      }
    },
    {
      "type": "response",
      "body": {
        "breakpoints": {
          "$array.contains": [{ "line": 11, "verified": true }]
        }
      }
    },
    {
      "type": "request",
      "command": "configurationDone",
      "arguments": {}
    },
    {
      "type": "event",
      "event": "stopped",
      "body": { "reason": "breakpoint", "threadId": "${{thread}}" }
    },
    {
      "type": "request",
      "command": "stepIn",
      "arguments": { "threadId": "{{thread}}" }
    },
    {
      "type": "event",
      "event": "stopped",
      "body": { "reason": "step", "threadId": "{{thread}}" }
    },
    {
      "type": "request",
      "command": "stackTrace",
      "arguments": { "threadId": "{{thread}}" }
    },
    {
      "type": "response",
      "body": {
        "stackFrames": {
          "$array.contains": [{ "name": "foo" }]
        }
      }
    },
    {
      "type": "request",
      "command": "stepIn",
      "arguments": { "threadId": "{{thread}}" }
    },
    {
      "type": "event",
      "event": "stopped",
      "body": { "reason": "step", "threadId": "{{thread}}" }
    },
    {
      "type": "request",
      "command": "stackTrace",
      "arguments": { "threadId": "{{thread}}" }
    },
    {
      "type": "response",
      "body": {
        "stackFrames": {
          "$array.contains": [{ "name": "foo" }]
        }
      }
    },
    {
      "type": "request",
      "command": "stepIn",
      "arguments": { "threadId": "{{thread}}" }
    },
    {
      "type": "event",
      "event": "stopped",
      "body": { "reason": "step", "threadId": "{{thread}}" }
    },
    {
      "type": "request",
      "command": "stackTrace",
      "arguments": { "threadId": "{{thread}}" }
    },
    {
      "type": "response",
      "body": {
        "stackFrames": {
          "$array.contains": [{ "name": "bar" }, { "name": "foo" }]
        }
      }
    },
    {
      "type": "request",
      "command": "continue",
      "arguments": { "threadId": "{{thread}}" }
    }
  ]
}
